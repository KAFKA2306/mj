{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8","text":"<p>\u3053\u306e\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u306b\u306f\u3001\u9ebb\u96c0\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u304c\u542b\u307e\u308c\u3066\u3044\u307e\u3059\u3002</p>"},{"location":"#_2","title":"\u76ee\u6b21","text":"<ul> <li>\u8981\u4ef6\u5b9a\u7fa9 - \u6a5f\u80fd\u8981\u4ef6\u3068\u975e\u6a5f\u80fd\u8981\u4ef6\u306e\u5b9a\u7fa9\u3002</li> <li>\u30a2\u30fc\u30ad\u30c6\u30af\u30c1\u30e3 \u30ea\u30d5\u30a1\u30ec\u30f3\u30b9 - \u30b7\u30b9\u30c6\u30e0\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3068\u305d\u306e\u76f8\u4e92\u4f5c\u7528\u306e\u6982\u8981\u3002</li> <li>\u76f8\u624b\u306e\u8aad\u307f\u3068\u5fc3\u7406 - \u76f8\u624b\u306e\u884c\u52d5\u3084\u300c\u7656\u300d\u304b\u3089\u624b\u3092\u8aad\u3080\u30c6\u30af\u30cb\u30c3\u30af\u3002</li> </ul>"},{"location":"ARCHITECTURE/","title":"\u30a2\u30fc\u30ad\u30c6\u30af\u30c1\u30e3 \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8","text":""},{"location":"ARCHITECTURE/#_2","title":"\u6982\u8981","text":"<p>\u3053\u306e\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u306f\u3001\u30e6\u30fc\u30b6\u30fc\u30a4\u30f3\u30bf\u30fc\u30d5\u30a7\u30fc\u30b9\uff08UI\uff09\u3068\u30b3\u30a2\u3068\u306a\u308b\u30c9\u30e1\u30a4\u30f3\u30ed\u30b8\u30c3\u30af\u3092\u5206\u96e2\u3057\u305f\u3001\u30af\u30ea\u30fc\u30f3\u3067\u30e2\u30b8\u30e5\u30fc\u30eb\u5316\u3055\u308c\u305f\u30a2\u30fc\u30ad\u30c6\u30af\u30c1\u30e3\u3092\u63a1\u7528\u3057\u3066\u3044\u307e\u3059\u3002\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u3068\u79d1\u5b66\u7684\u306a\u6b63\u78ba\u3055\u3092\u91cd\u8996\u3057\u3066\u8a2d\u8a08\u3055\u308c\u305f\u3001\u30af\u30e9\u30a4\u30a2\u30f3\u30c8\u30b5\u30a4\u30c9\u306eJavaScript\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3067\u3059\u3002</p>"},{"location":"ARCHITECTURE/#_3","title":"\u30b3\u30a2\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8","text":"<p>\u30b7\u30b9\u30c6\u30e0\u306f\u4e3b\u306b4\u3064\u306e\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3067\u69cb\u6210\u3055\u308c\u3066\u3044\u307e\u3059\uff1a</p> <ol> <li> <p>UI Controller (<code>src/ui/ui-controller.js</code>)</p> <ul> <li>\u5168\u4f53\u7684\u306a\u8abf\u6574\u5f79\uff08\u30aa\u30fc\u30b1\u30b9\u30c8\u30ec\u30fc\u30bf\u30fc\uff09\u3068\u3057\u3066\u6a5f\u80fd\u3057\u307e\u3059\u3002</li> <li>\u30e6\u30fc\u30b6\u30fc\u5165\u529b\uff08\u30af\u30ea\u30c3\u30af\u3001\u30ad\u30fc\u30dc\u30fc\u30c9\uff09\u3092\u51e6\u7406\u3057\u307e\u3059\u3002</li> <li>DOM\u3092\u66f4\u65b0\u3057\u3066\u30b2\u30fc\u30e0\u306e\u72b6\u614b\u3092\u63cf\u753b\u3057\u307e\u3059\u3002</li> <li>\u30a8\u30f3\u30b8\u30f3\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3068\u901a\u4fe1\u3057\u3066\u3001\u30c7\u30fc\u30bf\u3084\u5206\u6790\u7d50\u679c\u3092\u53d6\u5f97\u3057\u307e\u3059\u3002</li> </ul> </li> <li> <p>Mahjong Engine (<code>src/core/mahjong-engine.js</code>)</p> <ul> <li>\u30b3\u30a2\u3068\u306a\u308b\u30c9\u30e1\u30a4\u30f3\u30ed\u30b8\u30c3\u30af\u3067\u3059\u3002</li> <li>\u30b2\u30fc\u30e0\u306e\u72b6\u614b\u3001\u724c\u306e\u7ba1\u7406\u3001\u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u8a08\u7b97\u3001\u30eb\u30fc\u30eb\u306e\u9069\u7528\u3092\u51e6\u7406\u3057\u307e\u3059\u3002</li> <li>\u548c\u4e86\uff08\u30a2\u30ac\u30ea\uff09\u5224\u5b9a\u306e\u305f\u3081\u306e\u9ad8\u6027\u80fd\u306a\u30a2\u30eb\u30b4\u30ea\u30ba\u30e0\u3092\u63d0\u4f9b\u3057\u307e\u3059\u3002</li> </ul> </li> <li> <p>Yaku Calculator (<code>src/core/yaku-calculator.js</code>)</p> <ul> <li>\u5f79\uff08Yaku\uff09\u306e\u5224\u5b9a\u306b\u7279\u5316\u3057\u305f\u30e2\u30b8\u30e5\u30fc\u30eb\u3067\u3059\u3002</li> <li>\u6a19\u6e96\u7684\u306a\u65e5\u672c\u9ebb\u96c0\u306e\u30eb\u30fc\u30eb\u306b\u57fa\u3065\u3044\u3066\u624b\u3092\u8a55\u4fa1\u3057\u307e\u3059\u3002</li> </ul> </li> <li> <p>Probability Engine (<code>src/core/probability-engine.js</code>)</p> <ul> <li>\u8907\u96d1\u306a\u6570\u5b66\u7684\u8a08\u7b97\u3092\u51e6\u7406\u3057\u307e\u3059\u3002</li> <li>\u30e2\u30f3\u30c6\u30ab\u30eb\u30ed\u30b7\u30df\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u3068\u7d44\u307f\u5408\u308f\u305b\u8ad6\u3092\u4f7f\u7528\u3057\u3066\u3001\u548c\u4e86\u7387\u3084\u6709\u52b9\u724c\uff08\u53d7\u3051\u5165\u308c\uff09\u306e\u78ba\u7387\u3092\u8a08\u7b97\u3057\u307e\u3059\u3002</li> </ul> </li> </ol>"},{"location":"ARCHITECTURE/#_4","title":"\u4f9d\u5b58\u95a2\u4fc2\u30b0\u30e9\u30d5","text":"<pre><code>graph TD\n    UI[UI Controller] --&gt; ME[Mahjong Engine]\n    UI --&gt; YC[Yaku Calculator]\n    UI --&gt; PE[Probability Engine]\n\n    subgraph Domain Logic\n        ME\n        YC\n        PE\n    end\n\n    subgraph Interface\n        UI\n    end\n</code></pre>"},{"location":"ARCHITECTURE/#_5","title":"\u8a2d\u8a08\u539f\u5247","text":"<ul> <li>\u95a2\u5fc3\u306e\u5206\u96e2 (Separation of Concerns): UI\u306e\u63cf\u753b\u51e6\u7406\u306f\u3001\u30b2\u30fc\u30e0\u30ed\u30b8\u30c3\u30af\u304b\u3089\u5927\u5e45\u306b\u5207\u308a\u96e2\u3055\u308c\u3066\u3044\u307e\u3059\u3002</li> <li>\u30b9\u30c6\u30fc\u30c8\u30ec\u30b9\u6027 (Statelessness): \u30a8\u30f3\u30b8\u30f3\u7fa4\u306f\u4e3b\u306b\u3001\u6e21\u3055\u308c\u305f\u72b6\u614b\u3092\u51e6\u7406\u3059\u308b\u304b\u3001\u73fe\u5728\u306e\u5c40\u306b\u5fc5\u8981\u306a\u6700\u5c0f\u9650\u306e\u5185\u90e8\u72b6\u614b\u306e\u307f\u3092\u4fdd\u6301\u3059\u308b\u3088\u3046\u306b\u8a2d\u8a08\u3055\u308c\u3066\u3044\u307e\u3059\u3002</li> <li>\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9: \u30a8\u30f3\u30b8\u30f3\u306e\u4e3b\u8981\u30a2\u30eb\u30b4\u30ea\u30ba\u30e0\u306f\u3001\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u5206\u6790\uff08\u300c10\u5104\u4eba\u306e\u30e6\u30fc\u30b6\u30fc\u300d\u898f\u6a21\u306e\u30bf\u30fc\u30b2\u30c3\u30c8\uff09\u3092\u30b5\u30dd\u30fc\u30c8\u3059\u308b\u305f\u3081\u306b\u3001\u9ad8\u901f\u8a08\u7b97\u306b\u6700\u9069\u5316\u3055\u308c\u3066\u3044\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/","title":"\u9ebb\u96c0\u306b\u304a\u3051\u308b\u76f8\u624b\u306e\u8aad\u307f\u3068\u6280\u8853\u8ad6","text":""},{"location":"OPPONENT_READING/#_2","title":"\u6982\u8981","text":"<p>\u9ebb\u96c0\u3067\u76f8\u624b\u306e\u624b\u724c\u3092\u8aad\u3080\u6280\u8853\u306f\u3001\u5927\u304d\u304f\u5206\u3051\u3066\u300c\u6368\u3066\u724c\u5206\u6790\uff08\u7406\u8a70\u3081\uff09\u300d\u3068\u300c\u5fc3\u7406\u7684\u306a\u8aad\u307f\uff08\u7656\u30fb\u30c6\u30eb\uff09\u300d\u306e2\u3064\u306b\u5206\u985e\u3055\u308c\u307e\u3059\u3002\u672c\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3067\u306f\u3001\u6368\u3066\u724c\u304b\u3089\u8ad6\u7406\u7684\u306b\u5371\u967a\u724c\u3092\u63a8\u6e2c\u3059\u308b\u6280\u8853\u3001\u526f\u9732\uff08\u9cf4\u304d\uff09\u8aad\u307f\u3001\u5f79\u3078\u306e\u5bfe\u5fdc\u3001\u305d\u3057\u3066\u5bfe\u4eba\u6226\u7279\u6709\u306e\u5fc3\u7406\u7684\u6d1e\u5bdf\u3092\u89e3\u8aac\u3057\u307e\u3059\u3002</p>"},{"location":"OPPONENT_READING/#1","title":"1. \u6368\u3066\u724c\u5206\u6790\uff08\u57fa\u672c\u3068\u624b\u51fa\u3057\u30c4\u30e2\u5207\u308a\uff09","text":"<p>\u76f8\u624b\u306e\u6368\u3066\u724c\uff08\u6cb3\uff09\u306f\u3001\u60c5\u5831\u306e\u5b9d\u5eab\u3067\u3059\u3002\u6700\u3082\u91cd\u8981\u306a\u306e\u306f\u300c\u624b\u51fa\u3057\u300d\u3068\u300c\u30c4\u30e2\u5207\u308a\u300d\u306e\u9055\u3044\u3092\u898b\u6975\u3081\u308b\u3053\u3068\u3067\u3059\u3002</p> <ul> <li> <p>\u30c4\u30e2\u5207\u308a\uff08\u6697\u3044\u8868\u793a/\u30b0\u30ec\u30fc\u7b49\uff09:</p> <ul> <li>\u30c4\u30e2\u3063\u305f\u724c\u3092\u305d\u306e\u307e\u307e\u6368\u3066\u308b\u884c\u70ba\u3002</li> <li>\u610f\u5473: \u624b\u724c\u304c\u9032\u884c\u3057\u3066\u3044\u306a\u3044\u3001\u307e\u305f\u306f\u5909\u5316\u3055\u305b\u308b\u4fa1\u5024\u304c\u306a\u3044\u3002</li> <li>\u8aad\u307f: \u30c4\u30e2\u5207\u308a\u304c\u9577\u304f\u7d9a\u304f\u5834\u5408\u3001\u305d\u306e\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u300c\u30c6\u30f3\u30d1\u30a4\u3057\u3066\u3044\u308b\u300d\u304b\u3001\u5b8c\u5168\u306b\u30aa\u30ea\u3066\u3044\u308b\u300c\u30d9\u30bf\u30aa\u30ea\u300d\u72b6\u614b\u306e\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3067\u3059\u3002</li> </ul> </li> <li> <p>\u624b\u51fa\u3057\uff08\u660e\u308b\u3044\u8868\u793a/\u901a\u5e38\u7b49\uff09:</p> <ul> <li>\u624b\u724c\u306e\u4e2d\u304b\u3089\u724c\u3092\u9078\u3093\u3067\u6368\u3066\u308b\u884c\u70ba\u3002</li> <li>\u610f\u5473: \u624b\u306e\u69cb\u6210\u304c\u5909\u5316\u3057\u305f\u3001\u3042\u308b\u3044\u306f\u5b89\u5168\u724c\u3068\u5165\u308c\u66ff\u3048\u305f\u3002</li> <li>\u8aad\u307f:<ul> <li>\u95a2\u9023\u724c\u306e\u6240\u6301: \u624b\u51fa\u3057\u3055\u308c\u305f\u724c\u306e\u5468\u8fba\u306f\u3001\u624b\u724c\u306e\u4e2d\u306b\u6301\u3063\u3066\u3044\u305f\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3067\u3059\u3002\u307e\u305f\u3001\u305d\u306e\u5468\u8fba\u304c\u5371\u967a\u306b\u306a\u308b\uff08\u307e\u305f\u306f\u5b89\u5168\u306b\u306a\u308b\uff09\u30d2\u30f3\u30c8\u306b\u306a\u308a\u307e\u3059\u3002</li> <li>\u5b89\u724c\u4fdd\u6301: \u5371\u967a\u306a\u751f\u724c\uff08\u30b7\u30e7\u30f3\u30d1\u30a4\uff09\u3092\u6b8b\u3057\u3066\u5b89\u5168\u724c\u3092\u624b\u51fa\u3057\u3057\u305f\u5834\u5408\u3001\u653b\u6483\u614b\u52e2\uff08\u30a4\u30fc\u30b7\u30e3\u30f3\u30c6\u30f3\u3084\u30c6\u30f3\u30d1\u30a4\uff09\u3067\u3042\u308b\u3053\u3068\u3092\u5f37\u304f\u793a\u5506\u3057\u307e\u3059\u3002</li> <li>\u7a7a\u5207\u308a: \u30c6\u30f3\u30d1\u30a4\u3057\u3066\u3044\u308b\u304c\u3001\u624b\u724c\u306b\u3042\u308b\u724c\u3068\u540c\u3058\u724c\u3092\u30c4\u30e2\u3063\u305f\u6642\u306b\u308f\u3056\u3068\u624b\u724c\u306e\u65b9\u3092\u5207\u308b\u3053\u3068\u3067\u3001\u307e\u3060\u30ce\u30fc\u30c6\u30f3\u306e\u3088\u3046\u306b\u898b\u305b\u304b\u3051\u308b\u6280\u8853\u3067\u3059\u3002</li> </ul> </li> </ul> </li> </ul>"},{"location":"OPPONENT_READING/#2","title":"2. \u9632\u5fa1\u7406\u8ad6\uff08\u5b88\u308a\u306e\u30bb\u30aa\u30ea\u30fc\uff09","text":"<p>\u653e\u9283\uff08\u30ed\u30f3\u3055\u308c\u308b\u3053\u3068\uff09\u3092\u907f\u3051\u308b\u305f\u3081\u306e\u8ad6\u7406\u7684\u306a\u9632\u5fa1\u6280\u8853\u3067\u3059\u3002</p>"},{"location":"OPPONENT_READING/#21-suji","title":"2.1 \u30b9\u30b8\uff08Suji\uff09","text":"<p>\u4e21\u9762\u5f85\u3061\u306b\u5bfe\u3059\u308b\u5b89\u5168\u5ea6\u306e\u7406\u8ad6\u3067\u3059\u3002\u76f8\u624b\u304c\u4e21\u9762\u5f85\u3061\u306e\u5834\u5408\u3001\u7279\u5b9a\u306e\u724c\u304c\u901a\u3063\u3066\u3044\u308c\u3070\u3001\u305d\u306e\u300c\u30b9\u30b8\u300d\u306b\u3042\u305f\u308b\u724c\u3082\u901a\u308b\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3068\u3044\u3046\u8003\u3048\u65b9\u3067\u3059\u3002</p> <ul> <li>1-4-7\u306e\u6cd5\u5247: \u300c4\u300d\u304c\u6368\u3066\u3089\u308c\u3066\u3044\u308c\u3070\u3001\u76f8\u624b\u306f\u300c23\u300d\u3084\u300c56\u300d\u306e\u4e21\u9762\u5f85\u3061\u3067\u5f85\u3066\u306a\u3044\u305f\u3081\u3001\u300c1\u300d\u3068\u300c7\u300d\u306f\u4e21\u9762\u5f85\u3061\u306b\u5bfe\u3057\u3066\u5b89\u5168\u3067\u3059\u3002</li> <li>2-5-8\u306e\u6cd5\u5247: \u300c5\u300d\u304c\u6368\u3066\u3089\u308c\u3066\u3044\u308c\u3070\u3001\u300c2\u300d\u3068\u300c8\u300d\u306f\u4e21\u9762\u5f85\u3061\u306b\u5bfe\u3057\u3066\u5b89\u5168\u3067\u3059\u3002</li> <li>3-6-9\u306e\u6cd5\u5247: \u300c6\u300d\u304c\u6368\u3066\u3089\u308c\u3066\u3044\u308c\u3070\u3001\u300c3\u300d\u3068\u300c9\u300d\u306f\u4e21\u9762\u5f85\u3061\u306b\u5bfe\u3057\u3066\u5b89\u5168\u3067\u3059\u3002</li> </ul> <p>\u6ce8\u610f: \u30b9\u30b8\u306f\u3042\u304f\u307e\u3067\u300c\u4e21\u9762\u5f85\u3061\u300d\u306b\u5bfe\u3059\u308b\u5b89\u5168\u3067\u3059\u3002\u30ab\u30f3\u30c1\u30e3\u30f3\u3001\u30da\u30f3\u30c1\u30e3\u30f3\u3001\u5358\u9a0e\u5f85\u3061\u306b\u306f\u901a\u7528\u3057\u307e\u305b\u3093\u304c\u3001\u78ba\u7387\u306f\u5927\u5e45\u306b\u4e0b\u304c\u308a\u307e\u3059\u3002</p>"},{"location":"OPPONENT_READING/#22-kabe-no-chance","title":"2.2 \u30ab\u30d9\uff08Kabe - No Chance\uff09","text":"<p>\u81ea\u5206\u306e\u624b\u724c\u3068\u898b\u3048\u3066\u3044\u308b\u724c\u3092\u5229\u7528\u3057\u3066\u3001\u76f8\u624b\u304c\u5f85\u3061\u3092\u4f5c\u308c\u306a\u3044\u3053\u3068\u3092\u8a3c\u660e\u3059\u308b\u7406\u8ad6\u3067\u3059\u3002</p> <ul> <li>\u30ce\u30fc\u30c1\u30e3\u30f3\u30b9: \u3042\u308b\u6570\u724c\u304c\u5834\u306b4\u679a\u3059\u3079\u3066\u898b\u3048\u3066\u3044\u308b\u5834\u5408\u3001\u305d\u306e\u724c\u3092\u4f7f\u3063\u305f\u9806\u5b50\uff08\u30b7\u30e5\u30f3\u30c4\uff09\u306f\u4f5c\u308c\u307e\u305b\u3093\u3002<ul> <li>\u4f8b: \u300c8\u300d\u304c4\u679a\u898b\u3048\u3066\u3044\u308b \u2192 \u76f8\u624b\u306f\u300c78\u300d\u3084\u300c89\u300d\u306e\u5f62\u3092\u6301\u3066\u306a\u3044 \u2192 \u300c9\u300d\u3067\u5f85\u3064\uff086789\u3001789\uff09\u3053\u3068\u304c\u7269\u7406\u7684\u306b\u4e0d\u53ef\u80fd \u2192 \u300c9\u300d\u306f\u5b89\u5168\u3002</li> </ul> </li> <li>\u30ef\u30f3\u30c1\u30e3\u30f3\u30b9: 3\u679a\u898b\u3048\u3066\u3044\u308b\u5834\u5408\u3002\u6b8b\u308a1\u679a\u3092\u76f8\u624b\u304c\u6301\u3063\u3066\u3044\u306a\u3051\u308c\u3070\u5b89\u5168\u3067\u3059\u304c\u3001\u30ce\u30fc\u30c1\u30e3\u30f3\u30b9\u307b\u3069\u306e\u4fe1\u983c\u5ea6\u306f\u3042\u308a\u307e\u305b\u3093\u3002</li> </ul>"},{"location":"OPPONENT_READING/#23-sotogawa","title":"2.3 \u5916\u5074\uff08Sotogawa\uff09","text":"<p>\u5e8f\u76e4\u306b\u6368\u3066\u3089\u308c\u305f\u6570\u724c\u306e\u5916\u5074\uff081\u5bc4\u308a\u307e\u305f\u306f9\u5bc4\u308a\u306e\u724c\uff09\u306f\u6bd4\u8f03\u7684\u5b89\u5168\u3068\u3044\u3046\u30bb\u30aa\u30ea\u30fc\u3067\u3059\u3002</p> <ul> <li>\u4f8b: \u5e8f\u76e4\uff081\u6bb5\u76ee\uff09\u306b\u300c4\u300d\u304c\u6368\u3066\u3089\u308c\u3066\u3044\u308b\u5834\u5408\u3001\u305d\u306e\u5916\u5074\u306e\u300c1\u300d\u300c2\u300d\u300c3\u300d\u306f\u6bd4\u8f03\u7684\u5b89\u5168\u3002</li> <li>\u7406\u7531: \u5e8f\u76e4\u306b\u300c4\u300d\u3092\u6368\u3066\u308b\u3068\u3044\u3046\u3053\u3068\u306f\u3001\u300c234\u300d\u3084\u300c345\u300d\u3068\u3044\u3063\u305f\u9806\u5b50\u3092\u4f5c\u308b\u610f\u601d\u304c\u306a\u304b\u3063\u305f\uff08\u3042\u308b\u3044\u306f\u3059\u3067\u306b\u8db3\u308a\u3066\u3044\u308b\uff09\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u305f\u3081\u3001\u305d\u306e\u5468\u8fba\u3067\u5f85\u3063\u3066\u3044\u308b\u53ef\u80fd\u6027\u304c\u4e0b\u304c\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#3","title":"3. \u5f85\u3061\u8aad\u307f\u6280\u8853\uff08\u4e00\u70b9\u8aad\u307f\u306e\u30ed\u30b8\u30c3\u30af\uff09","text":"<p>\u76f8\u624b\u306e\u6368\u3066\u724c\u306e\u7279\u5b9a\u306e\u30d1\u30bf\u30fc\u30f3\u304b\u3089\u3001\u5177\u4f53\u7684\u306a\u5f85\u3061\u3092\u63a8\u6e2c\u3059\u308b\u6280\u8853\u3067\u3059\u3002</p>"},{"location":"OPPONENT_READING/#31-matagi-suji","title":"3.1 \u8de8\u304e\u30b9\u30b8\uff08Matagi-Suji\uff09","text":"<p>\u300c\u30ea\u30fc\u30c1\u5ba3\u8a00\u724c\u300d\u3084\u300c\u30c6\u30f3\u30d1\u30a4\u76f4\u524d\u306e\u624b\u51fa\u3057\u724c\u300d\u306e\u5468\u8fba\uff08\u8de8\u304e\uff09\u306f\u5371\u967a\u3068\u3044\u3046\u7406\u8ad6\u3002</p> <ul> <li>\u7406\u8ad6: \u591a\u304f\u306e\u30d7\u30ec\u30a4\u30e4\u30fc\u306f\u3001\u30c6\u30f3\u30d1\u30a4\u3059\u308b\u76f4\u524d\u307e\u3067\u4e21\u9762\u5909\u5316\u306a\u3069\u3092\u671f\u5f85\u3057\u3066\u3001\u5c06\u6765\u306e\u5f85\u3061\u306b\u95a2\u9023\u3059\u308b\u724c\u3092\u6301\u3063\u3066\u3044\u307e\u3059\u3002</li> <li>\u4f8b: \u300c5\u300d\u3092\u624b\u51fa\u3057\u3057\u3066\u30ea\u30fc\u30c1 \u2192 \u300c5\u300d\u3092\u307e\u305f\u3050\u300c3-6\u300d\u3084\u300c4-7\u300d\u5f85\u3061\u304c\u672c\u7dda\uff08\u5371\u967a\uff09\u3068\u306a\u308a\u307e\u3059\u3002<ul> <li>\u300c46\u300d\u3092\u6301\u3063\u3066\u3044\u30665\u3092\u5207\u3063\u3066\u30ea\u30fc\u30c1\uff083-6\u5f85\u3061\uff09</li> <li>\u300c3455\u300d\u304b\u30895\u3092\u5207\u3063\u3066\u30ea\u30fc\u30c1\uff082-5\u5f85\u3061\u2026\u306f\u30d5\u30ea\u30c6\u30f3\u3067\u3059\u304c\u3001\u5f62\u3068\u3057\u3066\u306e\u4f8b\uff09</li> </ul> </li> </ul>"},{"location":"OPPONENT_READING/#32-ura-suji","title":"3.2 \u88cf\u30b9\u30b8\uff08Ura-Suji\uff09","text":"<p>\u5e8f\u76e4\u306b\u5207\u3089\u308c\u305f\u724c\u306e\u300c\u88cf\u5074\u300d\u306b\u5f53\u305f\u308b\u30b9\u30b8\u304c\u5371\u967a\u306b\u306a\u308b\u7406\u8ad6\u3002</p> <ul> <li>\u57fa\u672c: \u300c5\u300d\u304c\u5207\u3089\u308c\u305f\u3089\u3001\u300c1-4\u300d\u307e\u305f\u306f\u300c6-9\u300d\u304c\u5371\u967a\u3002</li> <li>\u7406\u7531: \u300c135\u300d\u304b\u30895\u3092\u5207\u3063\u30661-3\u56fa\u5b9a\uff082\u5f85\u3061\uff09\u2192\u305d\u306e\u5f8c\u5909\u5316\u3057\u30661-4\u5f85\u3061\u306b\u306a\u308b\u3001\u306a\u3069\u306e\u624b\u4f5c\u308a\u624b\u9806\u304b\u3089\u5c0e\u304b\u308c\u307e\u3059\u3002<ul> <li>1\u5207\u308a \u2192 4-7\u304c\u5371\u967a</li> <li>2\u5207\u308a \u2192 5-8\u304c\u5371\u967a</li> <li>...</li> </ul> </li> </ul>"},{"location":"OPPONENT_READING/#33-aida-yon-ken","title":"3.3 \u9593\u56db\u30b1\u30f3\uff08Aida-Yon-Ken\uff09","text":"<p>\u540c\u8272\u306e\u6570\u724c\u304c\u300c4\u3064\u98db\u3070\u3057\u300d\u3067\u6368\u3066\u3089\u308c\u3066\u3044\u308b\u5834\u5408\u3001\u305d\u306e\u9593\u306e\u30a8\u30ea\u30a2\uff08\u5185\u5074\uff09\u304c\u975e\u5e38\u306b\u5371\u967a\u3068\u3044\u3046\u7406\u8ad6\u3002</p> <ul> <li>\u4f8b: \u300c3\u300d\u3068\u300c8\u300d\u304c\u6368\u3066\u3089\u308c\u3066\u3044\u308b\u5834\u5408\uff08\u9593\u304c4\u30015\u30016\u30017\u306e4\u3064\uff09\u3002</li> <li>\u8aad\u307f: \u300c3\u300d\u3084\u300c8\u300d\u306f\u3044\u3089\u306a\u3044\u304c\u3001\u300c4567\u300d\u5468\u8fba\u306e\u724c\u3067\u624b\u304c\u307e\u3068\u307e\u3063\u3066\u3044\u308b\u53ef\u80fd\u6027\u304c\u9ad8\u304f\u3001\u3053\u306e\u300c\u9593\u300d\u306e\u724c\u304c\u5f85\u3061\u306b\u306a\u3063\u3066\u3044\u308b\uff08\u3042\u308b\u3044\u306f\u5371\u967a\u724c\u3067\u3042\u308b\uff09\u30b1\u30fc\u30b9\u304c\u591a\u3044\u3067\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#4-naki-yomi","title":"4. \u526f\u9732\u8aad\u307f\uff08Naki-Yomi\uff09","text":"<p>\u9cf4\u3044\u3066\u3044\u308b\uff08\u526f\u9732\u3057\u3066\u3044\u308b\uff09\u76f8\u624b\u306b\u5bfe\u3059\u308b\u8aad\u307f\u306e\u6280\u8853\u3067\u3059\u3002</p>"},{"location":"OPPONENT_READING/#41","title":"4.1 \u6652\u3057\u65b9\u304b\u3089\u306e\u60c5\u5831\uff08\u98df\u3044\u4f38\u3070\u3057\u30fb\u30b9\u30e9\u30a4\u30c9\uff09","text":"<p>\u9cf4\u3044\u305f\u3068\u304d\u306b\u300c\u3069\u306e\u724c\u3092\u6652\u3057\u305f\u304b\u300d\u3067\u624b\u724c\u306e\u69cb\u6210\u304c\u8aad\u3081\u307e\u3059\u3002</p> <ul> <li>\u98df\u3044\u4f38\u3070\u3057: \u300c34\u300d\u3092\u6301\u3063\u3066\u3044\u3066\u4e0a\u5bb6\u306e\u300c2\u300d\u3092\u30c1\u30fc\u3057\u3066\u300c5\u300d\u3092\u5207\u308b\uff08234\u69cb\u6210\u30675\u51e6\u5206\uff09\u3002<ul> <li>\u8aad\u307f: \u3053\u306e\u5834\u5408\u3001\u5143\u3005\u300c345\u300d\u306e\u9806\u5b50\u3092\u6301\u3063\u3066\u3044\u305f\u304b\u3001\u8907\u5408\u5f62\u3060\u3063\u305f\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002\u300c5\u300d\u306e\u5468\u8fba\uff08\u7279\u306b\u8de8\u304e\uff09\u306f\u5371\u967a\u3067\u3059\u3002</li> </ul> </li> <li>\u8d64\u30c9\u30e9\u306e\u5207\u308a\u51fa\u3057: \u8d645\u3092\u542b\u3093\u3067\u9cf4\u3044\u3066\u3001\u9ed25\u3092\u5207\u3063\u305f\u5834\u5408\u3001\u5358\u306b\u8d64\u30c9\u30e9\u3092\u4f7f\u3044\u305f\u304b\u3063\u305f\u3060\u3051\u306e\u5834\u5408\u3068\u3001\u5168\u5e2f\uff08\u30c1\u30e3\u30f3\u30bf\uff09\u306a\u3069\u306e\u5f79\u7d61\u307f\u306e\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#42","title":"4.2 \u5f79\u306e\u63a8\u6e2c","text":"<ul> <li>\u30d0\u30c3\u30af: \u5f79\u724c\uff08\u767d\u767a\u4e2d\u3084\u5834\u98a8\uff09\u304c\u898b\u3048\u3066\u3044\u306a\u3044\u306e\u306b\u3001\u6570\u724c\u306e\u30c1\u30fc\u30fb\u30dd\u30f3\u304b\u3089\u5165\u3063\u305f\u5834\u5408\u3001\u300c\u5f79\u724c\u30d0\u30c3\u30af\uff08\u5f8c\u4ed8\u3051\uff09\u300d\u306e\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3067\u3059\u3002\u751f\u724c\u306e\u5b57\u724c\u306f\u6975\u3081\u3066\u5371\u967a\u3067\u3059\u3002</li> <li>\u30af\u30a4\u30bf\u30f3: \u30bf\u30f3\u30e4\u30aa\u724c\uff082\u301c8\uff09\u306e\u307f\u3067\u9cf4\u3044\u3066\u3044\u308b\u5834\u5408\u30021\u30fb9\u30fb\u5b57\u724c\u306f\u57fa\u672c\u7684\u306b\u5b89\u5168\u3067\u3059\u304c\u3001\u30c9\u30e9\u304c\u30bf\u30f3\u30e4\u30aa\u724c\u306e\u5834\u5408\u3001\u9ad8\u5f97\u70b9\u306e\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#5-yaku-specific-reading","title":"5. \u5f79\u5225\u306e\u8aad\u307f\uff08Yaku-Specific Reading\uff09","text":"<p>\u7279\u5b9a\u306e\u5f79\u3092\u72d9\u3063\u3066\u3044\u308b\u6c17\u914d\u304c\u3042\u308b\u5834\u5408\u306e\u8aad\u307f\u3067\u3059\u3002</p> <ul> <li>\u30db\u30f3\u30a4\u30c4\u30fb\u30c1\u30f3\u30a4\u30c4\uff08\u67d3\u3081\u624b\uff09:<ul> <li>\u4f59\u5270\u724c\uff08\u6ea2\u308c\uff09: \u67d3\u3081\u3066\u3044\u308b\u8272\u306e\u724c\u304c\u624b\u51fa\u3057\u3067\u6368\u3066\u3089\u308c\u305f\u3089\u300c\u4f59\u3063\u3066\u3044\u308b\u300d\uff1d\u30c6\u30f3\u30d1\u30a4\u307e\u305f\u306f\u30a4\u30fc\u30b7\u30e3\u30f3\u30c6\u30f3\u306e\u5f37\u3044\u30b5\u30a4\u30f3\u3067\u3059\u3002</li> <li>\u4ed6\u8272\u306e\u6368\u3066\u724c: \u67d3\u3081\u3066\u3044\u308b\u8272\u4ee5\u5916\u306e\u724c\u304c\u3001\u5e8f\u76e4\u304b\u3089\u7121\u9020\u4f5c\u306b\uff08\u7279\u306b\u30c9\u30e9\u306a\u3069\u304c\uff09\u5207\u3089\u308c\u3066\u3044\u308b\u5834\u5408\u3001\u67d3\u3081\u624b\u306e\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3067\u3059\u3002</li> </ul> </li> <li>\u56fd\u58eb\u7121\u53cc:<ul> <li>\u7279\u5fb4: 1\u30fb9\u30fb\u5b57\u724c\u4ee5\u5916\uff08\u4e2d\u5f35\u724c\uff09\u304c\u5e8f\u76e4\u304b\u3089\u30d0\u30e9\u30d0\u30e9\u3068\u5207\u3089\u308c\u308b\u3002</li> <li>\u5371\u967a\u4fe1\u53f7: \u7d42\u76e4\u306b\u306a\u3063\u3066\u30821\u30fb9\u30fb\u5b57\u724c\u304c\u4f59\u3089\u306a\u3044\u3001\u3042\u308b\u3044\u306f1\u679a\u5207\u308c\u306e\u5b57\u724c\u304c\u624b\u51fa\u3057\u3067\u5207\u3089\u308c\u305f\u6642\u306f\u30c6\u30f3\u30d1\u30a4\u306e\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002</li> </ul> </li> <li>\u30c8\u30a4\u30c8\u30a4:<ul> <li>\u7279\u5fb4: \u30dd\u30f3\u304c2\u56de\u4ee5\u4e0a\u5165\u308a\u3001\u6368\u3066\u724c\u306e\u4e2d\u5f35\u724c\uff08\u7279\u306b\u30bf\u30fc\u30c4\u306b\u306a\u308a\u305d\u3046\u306a3-4\u30846-7\u306a\u3069\uff09\u304c\u624b\u51fa\u3057\u3067\u5207\u3089\u308c\u3066\u3044\u308b\u5834\u5408\u3001\u5bfe\u5b50\u5834\uff08\u30c8\u30a4\u30c4\u30d0\uff09\u306b\u306a\u3063\u3066\u3044\u308b\u53ef\u80fd\u6027\u304c\u3042\u308a\u307e\u3059\u3002\u751f\u724c\u306e\u653e\u9283\u306b\u6ce8\u610f\u304c\u5fc5\u8981\u3067\u3059\u3002</li> </ul> </li> </ul>"},{"location":"OPPONENT_READING/#6-advanced-defense","title":"6. \u5fdc\u7528\u9632\u5fa1\u6280\u8853\uff08Advanced Defense\uff09","text":"<p>\u30d9\u30bf\u30aa\u30ea\u4ee5\u4e0a\u306e\u6280\u8853\u3067\u3059\u3002</p>"},{"location":"OPPONENT_READING/#61-mawashi-uchi","title":"6.1 \u56de\u3057\u6253\u3061\uff08Mawashi-uchi\uff09","text":"<p>\u5b8c\u5168\u306b\u30aa\u30ea\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u5b89\u5168\u306a\u724c\u3092\u5207\u308a\u3064\u3064\u3001\u30c6\u30f3\u30d1\u30a4\u306e\u53ef\u80fd\u6027\u3092\u6b8b\u3059\u6253\u3061\u65b9\u3067\u3059\u3002 *   \u65b9\u6cd5: \u5371\u967a\u724c\u3092\u5f15\u3044\u305f\u3089\u3001\u624b\u724c\u306e\u4e2d\u306e\u73fe\u7269\uff08\u5b89\u5168\u724c\uff09\u3068\u5165\u308c\u66ff\u3048\u308b\u3002\u30b9\u30b8\u3084\u30ab\u30d9\u3092\u5229\u7528\u3057\u3066\u3001\u6bd4\u8f03\u7684\u5b89\u5168\u306a\u724c\u3067\u5f62\u3092\u7dad\u6301\u3059\u308b\u3002 *   \u76ee\u7684: \u5f62\u5f0f\u30c6\u30f3\u30d1\u30a4\uff08\u30ce\u30fc\u30c6\u30f3\u7f70\u7b26\u56de\u907f\uff09\u3084\u3001\u5b89\u624b\u3067\u306e\u304b\u308f\u3057\u624b\u3092\u72d9\u3044\u307e\u3059\u3002</p>"},{"location":"OPPONENT_READING/#62-awase-uchi","title":"6.2 \u5408\u308f\u305b\u6253\u3061\uff08Awase-uchi\uff09","text":"<ul> <li>\u5b9a\u7fa9: \u4e0a\u5bb6\u304c\u5207\u3063\u305f\u724c\u3068\u540c\u3058\u724c\u3092\u5373\u5ea7\u306b\u5207\u308b\u3053\u3068\u3002</li> <li>\u52b9\u679c: \u30d5\u30ea\u30c6\u30f3\u306e\u30eb\u30fc\u30eb\u4e0a\u3001\u4e0a\u5bb6\u304c\u901a\u3057\u305f\u724c\u306f\u305d\u306e\u5de1\u76ee\u306b\u304a\u3044\u3066\u8ab0\u306b\u3082\u30ed\u30f3\u3055\u308c\u307e\u305b\u3093\uff08\u540c\u5de1\u5185\u30d5\u30ea\u30c6\u30f3\uff09\u3002100%\u5b89\u5168\u306a\u9632\u5fa1\u7b56\u3067\u3059\u3002\u4e0b\u5bb6\u3084\u5bfe\u9762\u306b\u5bfe\u3059\u308b\u5b89\u5168\u3082\u78ba\u4fdd\u3067\u304d\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#7","title":"7. \u5fc3\u7406\u7684\u306a\u300c\u30c6\u30eb\u300d\u3068\u300c\u7656\u300d","text":"<p>\u30ea\u30a2\u30eb\u5bfe\u5c40\u306b\u304a\u3044\u3066\u3001\u7121\u610f\u8b58\u306e\u52d5\u4f5c\u306b\u73fe\u308c\u308b\u60c5\u5831\u3067\u3059\uff08\u30cd\u30c3\u30c8\u9ebb\u96c0\u3067\u3082\u300c\u9593\u300d\u3068\u3057\u3066\u73fe\u308c\u307e\u3059\uff09\u3002</p> <ul> <li>\u5f79\u724c\u306e\u300c\u9593\uff08\u307e\uff09\u300d: \u5b57\u724c\u3092\u6368\u3066\u308b\u524d\u306b\u4e00\u77ac\u6b62\u307e\u308b\u5834\u5408\u3001\u5bfe\u5b50\uff08\u30c8\u30a4\u30c4\uff09\u3067\u6301\u3063\u3066\u3044\u3066\u300c\u30dd\u30f3\u3059\u308b\u304b\u8ff7\u3063\u305f\u300d\u304b\u300c\u5b89\u5168\u724c\u3068\u3057\u3066\u6b8b\u3059\u304b\u8ff7\u3063\u305f\u300d\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3067\u3059\u3002</li> <li>\u67d3\u3081\u624b\u306e\u6ea2\u308c: \u4e0a\u8a18\u306e\u901a\u308a\u3001\u67d3\u3081\u8272\u304b\u3089\u624b\u51fa\u3057\u304c\u3042\u3063\u305f\u77ac\u9593\u306f\u8981\u6ce8\u610f\u3067\u3059\u3002</li> <li>\u7a7a\u5207\u308a\u30ea\u30fc\u30c1: \u30c4\u30e2\u5207\u308a\u3067\u3082\u3044\u3044\u724c\u3092\u3042\u3048\u3066\u624b\u51fa\u3057\u3057\u3066\u30ea\u30fc\u30c1\u3059\u308b\u5834\u5408\u3001\u5f85\u3061\u304c\u60aa\u3044\uff08\u30ab\u30f3\u30c1\u30e3\u30f3\u7b49\uff09\u306e\u3092\u96a0\u305d\u3046\u3068\u3057\u3066\u3044\u308b\u304b\u3001\u5f15\u3063\u304b\u3051\uff08\u30b9\u30b8\u5f85\u3061\u7b49\uff09\u3092\u72d9\u3063\u3066\u3044\u308b\u5fc3\u7406\u304c\u3042\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"OPPONENT_READING/#8","title":"8. \u307e\u3068\u3081","text":"<p>\u8aad\u307f\u306f\u300c\u7d76\u5bfe\u300d\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u304c\u3001\u52dd\u7387\u30921%\u3067\u3082\u4e0a\u3052\u308b\u305f\u3081\u306e\u6b66\u5668\u3067\u3059\u3002</p> <ol> <li>\u307e\u305a\u624b\u51fa\u3057\u30fb\u30c4\u30e2\u5207\u308a\u3092\u898b\u308b\u3002</li> <li>\u30ea\u30fc\u30c1\u304c\u6765\u305f\u3089\u73fe\u7269\uff08\u5168\u54e1\u306e\u6368\u3066\u724c\uff09 &gt; \u30b9\u30b8 &gt; \u30ab\u30d9 &gt; \u5916\u5074 \u306e\u9806\u3067\u5b89\u5168\u724c\u3092\u63a2\u3059\u3002</li> <li>\u526f\u9732\u3084\u6368\u3066\u724c\u306e\u504f\u308a\u304b\u3089\u5f79\u3092\u63a8\u6e2c\u3059\u308b\u3002</li> <li>\u4f59\u88d5\u304c\u3042\u308c\u3070\u8de8\u304e\u30b9\u30b8\u3084\u88cf\u30b9\u30b8\u3067\u4e00\u70b9\u8aad\u307f\u3092\u8a66\u307f\u308b\u3002</li> </ol> <p>\u3053\u306e\u512a\u5148\u9806\u4f4d\u3092\u5fd8\u308c\u306a\u3044\u3088\u3046\u306b\u3057\u307e\u3057\u3087\u3046\u3002</p>"},{"location":"SCENARIO_THEORY/","title":"\u9ebb\u96c0\u30b7\u30ca\u30ea\u30aa\u7406\u8ad6\u3068\u691c\u8a3c\u30ed\u30b8\u30c3\u30af (Scenario Theory &amp; Logic)","text":"<p>\u672c\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3067\u306f\u3001\u5404\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u30b7\u30ca\u30ea\u30aa\u306b\u304a\u3051\u308b\u300c\u6b63\u89e3\u300d\u306e\u6839\u62e0\u3068\u306a\u308b\u9ebb\u96c0\u7406\u8ad6\u3068\u3001\u30b7\u30b9\u30c6\u30e0\u5185\u90e8\u3067\u306e\u691c\u8a3c\u30ed\u30b8\u30c3\u30af\uff08<code>ScenarioValidator</code>\uff09\u306b\u3064\u3044\u3066\u89e3\u8aac\u3057\u307e\u3059\u3002</p>"},{"location":"SCENARIO_THEORY/#1-1-shanten-mastery-efficiency","title":"1. \u4e00\u5411\u8074\u30de\u30b9\u30bf\u30fc (1-Shanten Mastery / Efficiency)","text":""},{"location":"SCENARIO_THEORY/#theory","title":"\u7406\u8ad6\u7684\u80cc\u666f (Theory)","text":"<p>\u4e00\u5411\u8074\uff08\u30a4\u30fc\u30b7\u30e3\u30f3\u30c6\u30f3\uff09\u306b\u304a\u3044\u3066\u6700\u3082\u91cd\u8981\u306a\u6307\u6a19\u306f\u300c\u53d7\u3051\u5165\u308c\u679a\u6570\uff08Ukeire\uff09\u300d\u3068\u300c\u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u300d\u3067\u3059\u3002 \u73fe\u4ee3\u9ebb\u96c0\u306e\u30bb\u30aa\u30ea\u30fc\uff08\u6240\u8b02\u300c\u79d1\u5b66\u3059\u308b\u9ebb\u96c0\u300d\u4ee5\u964d\u306e\u7406\u8ad6\uff09\u3067\u306f\u3001\u4ee5\u4e0b\u306e\u512a\u5148\u9806\u4f4d\u3067\u6253\u724c\u3092\u9078\u629e\u3057\u307e\u3059\u3002</p> <ol> <li>\u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u3092\u7dad\u6301\u3059\u308b: \u8074\u724c\uff08\u30c6\u30f3\u30d1\u30a4\uff09\u307e\u3067\u306e\u8ddd\u96e2\u3092\u9060\u3056\u3051\u308b\u6253\u724c\u306f\u539f\u5247\u3068\u3057\u3066\u60aa\u624b\u3067\u3059\u3002</li> <li>\u6700\u5927\u53d7\u3051\u5165\u308c\u679a\u6570: \u8074\u724c\u306b\u81f3\u308b\u305f\u3081\u306e\u6709\u52b9\u724c\uff08Waiting Tiles\uff09\u306e\u679a\u6570\u3092\u6700\u5927\u5316\u3057\u307e\u3059\u3002</li> <li>\u826f\u5f62\u5909\u5316: \u53d7\u3051\u5165\u308c\u679a\u6570\u304c\u540c\u7b49\u3001\u3042\u308b\u3044\u306f\u50c5\u5dee\u306e\u5834\u5408\u3001\u6700\u7d42\u7684\u306a\u5f85\u3061\u304c\u826f\u5f62\uff08\u4e21\u9762\u4ee5\u4e0a\uff09\u306b\u306a\u308a\u3084\u3059\u3044\u724c\u3092\u6b8b\u3057\u307e\u3059\u3002</li> </ol>"},{"location":"SCENARIO_THEORY/#logic","title":"\u691c\u8a3c\u30ed\u30b8\u30c3\u30af (Logic)","text":"<p>\u30b7\u30b9\u30c6\u30e0\u306f\u4ee5\u4e0b\u306e\u57fa\u6e96\u3067\u30e6\u30fc\u30b6\u30fc\u306e\u6253\u724c\u3092\u5224\u5b9a\u3057\u307e\u3059\u3002</p> <ul> <li>Bad: \u6253\u724c\u306b\u3088\u3063\u3066\u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u304c\u4e0b\u304c\u3063\u305f\u5834\u5408\uff08\u4f8b\uff1a1\u5411\u8074 \u2192 2\u5411\u8074\uff09\u3002\u3053\u308c\u306f\u300c\u623b\u308a\u300d\u3068\u547c\u3070\u308c\u3001\u660e\u78ba\u306a\u30df\u30b9\u3068\u307f\u306a\u3055\u308c\u307e\u3059\u3002</li> <li>Suboptimal: \u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u306f\u7dad\u6301\u3057\u305f\u304c\u3001\u53d7\u3051\u5165\u308c\u679a\u6570\u304c\u6700\u5927\u5024\u3068\u6bd4\u8f03\u3057\u3066\u8457\u3057\u304f\u6e1b\u5c11\u3057\u305f\u5834\u5408\uff08\u30ed\u30b9 &gt; 2\u679a\u306a\u3069\uff09\u3002</li> <li>Excellent/Good: \u53d7\u3051\u5165\u308c\u679a\u6570\u304c\u6700\u5927\u3001\u3042\u308b\u3044\u306f\u6700\u5927\u3068\u307b\u307c\u540c\u7b49\uff08\u5fae\u5dee\uff09\u306e\u5834\u5408\u3002</li> </ul>"},{"location":"SCENARIO_THEORY/#2-riichi-decision","title":"2. \u30ea\u30fc\u30c1\u5224\u65ad (Riichi Decision)","text":""},{"location":"SCENARIO_THEORY/#theory_1","title":"\u7406\u8ad6\u7684\u80cc\u666f (Theory)","text":"<p>\u300c\u30ea\u30fc\u30c1\u3059\u308b\u304b\u3001\u30c0\u30de\u30c6\u30f3\uff08\u95c7\u8074\uff09\u306b\u3059\u308b\u304b\u300d\u306f\u3001\u671f\u5f85\u5024\uff08Expected Value: EV\uff09\u306e\u6bd4\u8f03\u306b\u3088\u3063\u3066\u5224\u65ad\u3055\u308c\u307e\u3059\u3002</p> <ul> <li>\u30ea\u30fc\u30c1\u6709\u5229\u306a\u6761\u4ef6:<ul> <li>\u6253\u70b9\u4e0a\u6607: \u30ea\u30fc\u30c1\u306b\u3088\u3063\u3066\u6253\u70b9\u304c\u5927\u304d\u304f\u4e0a\u304c\u308b\uff08\u4f8b\uff1a\u306e\u307f\u624b \u2192 \u30ea\u30fc\u30c1\u30fb\u88cf1\uff09\u3002</li> <li>\u826f\u5f62\u5f85\u3061: \u4e21\u9762\u5f85\u3061\u306a\u3069\u3001\u30c4\u30e2\u7387\u30fb\u548c\u4e86\u7387\u304c\u9ad8\u3044\u72b6\u614b\u3002</li> <li>\u5148\u5236: \u4ed6\u5bb6\u304c\u30c6\u30f3\u30d1\u30a4\u3057\u3066\u3044\u306a\u3044\uff08\u3088\u3046\u306b\u898b\u3048\u308b\uff09\u5e8f\u76e4\u30fb\u4e2d\u76e4\u3002</li> </ul> </li> <li>\u30c0\u30de\u30c6\u30f3\u6709\u5229\u306a\u6761\u4ef6:<ul> <li>\u624b\u66ff\u308f\u308a: \u5909\u5316\u3059\u308c\u3070\u6253\u70b9\u3084\u5f85\u3061\u304c\u5287\u7684\u306b\u826f\u304f\u306a\u308b\u5834\u5408\u3002</li> <li>\u9ad8\u6253\u70b9: \u30c0\u30de\u30c6\u30f3\u3067\u3059\u3067\u306b\u6e80\u8cab\u4ee5\u4e0a\u3042\u308a\u3001\u30ea\u30fc\u30c1\u306b\u3088\u308b\u6253\u70b9\u4e0a\u6607\u306e\u6069\u6075\u304c\u5c11\u306a\u3044\u5834\u5408\u3002</li> <li>\u5b88\u5099\u7684: \u5371\u967a\u306a\u72b6\u614b\u3067\u3001\u3044\u3064\u3067\u3082\u30aa\u30ea\u3089\u308c\u308b\u3088\u3046\u306b\u3057\u305f\u3044\u5834\u5408\u3002</li> </ul> </li> </ul>"},{"location":"SCENARIO_THEORY/#logic_1","title":"\u691c\u8a3c\u30ed\u30b8\u30c3\u30af (Logic)","text":"<p>\u30b7\u30b9\u30c6\u30e0\u306f <code>ExpectedValue</code> (EV) \u3092\u7b97\u51fa\u3057\u3066\u6bd4\u8f03\u3057\u307e\u3059\u3002</p> <ul> <li><code>EV(Riichi) &gt; EV(Dama) * 1.2</code> (\u6709\u610f\u306a\u5dee\u304c\u3042\u308b) \u2192 \u30ea\u30fc\u30c1\u63a8\u5968\uff08\u3057\u306a\u3044\u5834\u5408\u306f\u30df\u30b9\uff09\u3002</li> <li><code>EV(Dama)</code> \u304c\u9ad8\u304f\u3001<code>EV(Riichi)</code> \u3068\u306e\u5dee\u304c\u5c0f\u3055\u3044 \u2192 \u30c0\u30de\u30c6\u30f3\u3082\u6b63\u89e3\u3002</li> <li>\u57fa\u672c\u7684\u306b\u306f\u300c\u5148\u5236\u826f\u5f62\u306f\u30ea\u30fc\u30c1\u300d\u306e\u30bb\u30aa\u30ea\u30fc\u306b\u5f93\u3044\u3001\u653b\u6483\u7684\u306a\u9078\u629e\u3092\u9ad8\u304f\u8a55\u4fa1\u3059\u308b\u50be\u5411\u306b\u3042\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"SCENARIO_THEORY/#3-defensive-play","title":"3. \u9632\u5fa1\u30fb\u5b88\u5099 (Defensive Play)","text":""},{"location":"SCENARIO_THEORY/#theory_2","title":"\u7406\u8ad6\u7684\u80cc\u666f (Theory)","text":"<p>\u5b88\u5099\u30b7\u30ca\u30ea\u30aa\u3067\u306f\u3001\u76f8\u624b\u304b\u3089\u306e\u653b\u6483\uff08\u30ea\u30fc\u30c1\u7b49\uff09\u3092\u60f3\u5b9a\u3057\u3001\u300c\u653e\u9283\u7387\uff08Deal-in Rate\uff09\u300d\u3092\u6700\u5c0f\u5316\u3059\u308b\u3053\u3068\u304c\u6c42\u3081\u3089\u308c\u307e\u3059\u3002</p> <ul> <li>\u5b89\u5168\u724c\u306e\u968e\u5c64:<ol> <li>\u73fe\u7269 (Genbutsu): \u76f8\u624b\u304c\u6368\u3066\u305f\u724c\uff08100%\u5b89\u5168\uff09\u3002</li> <li>\u5b57\u724c (Honors): \u7279\u306b\u5834\u306b\u51fa\u3066\u3044\u308b\u30aa\u30bf\u98a8\u306a\u3069\u306f\u5b89\u5168\u5ea6\u304c\u9ad8\u3044\u3002</li> <li>\u30b9\u30b8 (Suji): \u4e21\u9762\u5f85\u3061\u306b\u5f53\u305f\u3089\u306a\u3044\u724c\uff08\u4f8b\uff1a4\u304c\u5207\u308c\u3066\u3044\u308b\u6642\u306e1\u30687\uff09\u3002</li> <li>\u30ab\u30d9 (Kabe): \u81ea\u8eab\u30674\u679a\u898b\u3048\u3066\u3044\u308b\u724c\u306e\u5916\u5074\u3002</li> </ol> </li> </ul>"},{"location":"SCENARIO_THEORY/#logic_2","title":"\u691c\u8a3c\u30ed\u30b8\u30c3\u30af (Logic)","text":"<p>\u30e6\u30fc\u30b6\u30fc\u304c\u9078\u3093\u3060\u6253\u724c\u306e\u300c\u5b89\u5168\u6027\u300d\u3092\u5224\u5b9a\u3057\u307e\u3059\u3002</p> <ul> <li>Dangerous: \u7121\u7b4b\uff08\u30b9\u30b8\u3067\u306f\u306a\u3044\uff09\u306e\u4e2d\u5f35\u724c\uff08\u6570\u724c\u306e\u771f\u3093\u4e2d\uff09\u306a\u3069\u3001\u653e\u9283\u30ea\u30b9\u30af\u304c\u9ad8\u3044\u724c\u3002</li> <li>Aggressive: \u5371\u967a\u724c\u3060\u304c\u3001\u81ea\u8eab\u306e\u624b\u304c\u52dd\u8ca0\u624b\uff08\u30c6\u30f3\u30d1\u30a4\u7b49\uff09\u3067\u3042\u308b\u5834\u5408\u3001\u300c\u62bc\u3059\u300d\u5224\u65ad\u3068\u3057\u3066\u8a31\u5bb9\u3055\u308c\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002</li> <li>Excellent: \u73fe\u7269\u3084\u30b9\u30b8\u306a\u3069\u3001\u7406\u8ad6\u7684\u306b\u5b89\u5168\u5ea6\u304c\u4fdd\u8a3c\u3055\u308c\u3066\u3044\u308b\u724c\u3002</li> </ul>"},{"location":"SCENARIO_THEORY/#4-yaku-building","title":"4. \u624b\u5f79\u4f5c\u308a (Yaku Building)","text":""},{"location":"SCENARIO_THEORY/#theory_3","title":"\u7406\u8ad6\u7684\u80cc\u666f (Theory)","text":"<p>\u5358\u306a\u308b\u52b9\u7387\u3060\u3051\u3067\u306a\u304f\u3001\u7279\u5b9a\u306e\u5f79\uff08Yaku\uff09\u3092\u72d9\u3046\u3053\u3068\u3067\u6253\u70b9\u3092\u9ad8\u3081\u308b\u6280\u8853\u3067\u3059\u3002</p> <ul> <li>\u30bf\u30f3\u30e4\u30aa: 1,9,\u5b57\u724c\u3092\u5207\u308a\u30012~8\u306e\u724c\u3092\u6b8b\u3059\u3002</li> <li>\u4e09\u8272\u540c\u9806: \u7570\u306a\u308b\u8272\u3067\u540c\u3058\u6570\u5b57\u306e\u9806\u5b50\u3092\u4f5c\u308b\u610f\u8b58\u3002</li> <li>\u4e00\u6c17\u901a\u8cab: \u540c\u8272\u30671~9\u3092\u63c3\u3048\u308b\u610f\u8b58\u3002</li> </ul>"},{"location":"SCENARIO_THEORY/#logic_3","title":"\u691c\u8a3c\u30ed\u30b8\u30c3\u30af (Logic)","text":"<p>\u6307\u5b9a\u3055\u308c\u305f\u30b7\u30ca\u30ea\u30aa\u306e\u300c\u30bf\u30fc\u30b2\u30c3\u30c8\u5f79\u300d\u3078\u306e\u9069\u5408\u6027\u3092\u5224\u5b9a\u3057\u307e\u3059\u3002</p> <ul> <li>\u52b9\u7387\uff08\u53d7\u3051\u5165\u308c\u679a\u6570\uff09\u3092\u591a\u5c11\u72a0\u7272\u306b\u3057\u3066\u3082\u3001\u624b\u5f79\u306e\u78ba\u5b9a\u3084\u624b\u5f79\u306e\u7a2e\u3092\u6b8b\u3059\u6253\u724c\u304c\u9ad8\u304f\u8a55\u4fa1\u3055\u308c\u307e\u3059\u3002</li> <li>\u9006\u306b\u3001\u52b9\u7387\u304c\u826f\u304f\u3066\u3082\u624b\u5f79\u3092\u6d88\u3057\u3066\u3057\u307e\u3046\u6253\u724c\uff08\u4f8b\uff1a\u30bf\u30f3\u30e4\u30aa\u72d9\u3044\u30672\u3092\u5207\u308a1\u3092\u6b8b\u3059\uff09\u306f\u4f4e\u8a55\u4fa1\u3068\u306a\u308a\u307e\u3059\u3002</li> </ul>"},{"location":"SCENARIO_THEORY/#5-opponent-reading","title":"5. \u76f8\u624b\u8aad\u307f (Opponent Reading)","text":"<p>\u8a73\u7d30\u306a\u8aad\u307f\u306e\u6280\u8853\u306b\u3064\u3044\u3066\u306f OPPONENT_READING.md \u3092\u53c2\u7167\u3057\u3066\u304f\u3060\u3055\u3044\u3002 \u691c\u8a3c\u3067\u306f\u3001\u4ee5\u4e0b\u306e\u884c\u52d5\u3092\u8a55\u4fa1\u3057\u307e\u3059\u3002</p> <ul> <li>\u624b\u51fa\u3057\u30fb\u30c4\u30e2\u5207\u308a\u306e\u8a18\u61b6: \u76f8\u624b\u306e\u624b\u51fa\u3057\u724c\u5468\u8fba\u3092\u8b66\u6212\u3067\u304d\u3066\u3044\u308b\u304b\u3002</li> <li>\u5bfe\u5fdc: \u76f8\u624b\u306e\u30ea\u30fc\u30c1\u3084\u9732\u9aa8\u306a\u67d3\u3081\u624b\u306b\u5bfe\u3057\u3066\u3001\u9069\u5207\u306a\u30bf\u30a4\u30df\u30f3\u30b0\u3067\u30d9\u30bf\u30aa\u30ea\uff08\u9632\u5fa1\uff09\u306b\u5207\u308a\u66ff\u3048\u3089\u308c\u3066\u3044\u308b\u304b\u3002</li> </ul>"},{"location":"req/","title":"\u8981\u4ef6\u5b9a\u7fa9","text":""},{"location":"req/#_2","title":"\u6982\u8981","text":"<p>Solo Mahjong Practice Machine \u306f\u30012024\u5e74\u306eAI\u7814\u7a76\u3092\u7d71\u5408\u3057\u305f\u79d1\u5b66\u7684\u306a\u9ebb\u96c0\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3067\u3059\u3002</p>"},{"location":"req/#_3","title":"\u6a5f\u80fd\u8981\u4ef6","text":""},{"location":"req/#_4","title":"\u30b3\u30a2\u6a5f\u80fd","text":"<ul> <li>\u624b\u724c\u306e\u751f\u6210\u3068\u8868\u793a</li> <li>\u30b7\u30e3\u30f3\u30c6\u30f3\u6570\u8a08\u7b97</li> <li>\u5f79\u5224\u5b9a\uff0830\u7a2e\u4ee5\u4e0a\u306e\u5f79\u306b\u5bfe\u5fdc\uff09</li> <li>\u671f\u5f85\u5024\u8a08\u7b97</li> <li>\u548c\u4e86\u78ba\u7387\u8a08\u7b97</li> <li>\u653e\u9283\u30ea\u30b9\u30af\u8a55\u4fa1</li> </ul>"},{"location":"req/#_5","title":"\u5f79\u5224\u5b9a\uff08\u5b9f\u88c5\u6e08\u307f\uff09","text":"\u30ab\u30c6\u30b4\u30ea \u5f79\u540d \u7ffb\u6570 \u57fa\u672c\u5f79 \u30ea\u30fc\u30c1\u3001\u9580\u524d\u6e05\u81ea\u6478\u548c\u3001\u4e00\u767a 1\u7ffb \u57fa\u672c\u5f79 \u30bf\u30f3\u30e4\u30aa\u3001\u5e73\u548c\u3001\u4e00\u76c3\u53e3 1\u7ffb \u57fa\u672c\u5f79 \u5f79\u724c\uff08\u98a8\u724c\u30fb\u4e09\u5143\u724c\uff09 1\u7ffb 2\u7ffb\u5f79 \u30c0\u30d6\u30eb\u30ea\u30fc\u30c1\u3001\u4e09\u8272\u540c\u9806\u3001\u4e00\u6c17\u901a\u8cab 2\u7ffb 2\u7ffb\u5f79 \u30c1\u30e3\u30f3\u30bf\u3001\u4e03\u5bfe\u5b50\u3001\u5bfe\u3005\u548c 2\u7ffb 2\u7ffb\u5f79 \u4e09\u6697\u523b\u3001\u4e09\u8272\u540c\u523b\u3001\u4e09\u69d3\u5b50 2\u7ffb 2\u7ffb\u5f79 \u6df7\u8001\u982d\u3001\u5c0f\u4e09\u5143 2\u7ffb 3\u7ffb\u5f79 \u6df7\u4e00\u8272\u3001\u7d14\u30c1\u30e3\u30f3\u3001\u4e8c\u76c3\u53e3 3\u7ffb 6\u7ffb\u5f79 \u6e05\u4e00\u8272 6\u7ffb \u5f79\u6e80 \u56fd\u58eb\u7121\u53cc\u3001\u56db\u6697\u523b\u3001\u5927\u4e09\u5143 13\u7ffb \u5f79\u6e80 \u5c0f\u56db\u559c\u3001\u5b57\u4e00\u8272\u3001\u6e05\u8001\u982d 13\u7ffb \u5f79\u6e80 \u7dd1\u4e00\u8272\u3001\u56db\u69d3\u5b50 13\u7ffb"},{"location":"req/#_6","title":"\u7df4\u7fd2\u30b7\u30ca\u30ea\u30aa","text":"<ol> <li>1-Shanten Mastery - \u8907\u6570\u306e\u5f85\u3061\u5f62\u3068\u52b9\u7387</li> <li>Riichi Decision - \u30ea\u30fc\u30c1\u5ba3\u8a00 vs \u30c0\u30de\u30c6\u30f3\u5224\u65ad</li> <li>Defensive Play - \u5b89\u5168\u724c\u9078\u629e\u3068\u8aad\u307f</li> <li>Yaku Building - \u7ffb\u6570\u6700\u9069\u5316</li> </ol>"},{"location":"req/#_7","title":"\u975e\u6a5f\u80fd\u8981\u4ef6","text":""},{"location":"req/#_8","title":"\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9","text":"<ul> <li>LRU\u30ad\u30e3\u30c3\u30b7\u30e5\u306b\u3088\u308b\u9ad8\u901f\u8a08\u7b97\uff0810,000\u30a8\u30f3\u30c8\u30ea\u4e0a\u9650\uff09</li> <li>\u30d3\u30c3\u30c8\u6f14\u7b97\u306b\u3088\u308b O(1) \u724c\u64cd\u4f5c</li> <li>10\u5104\u30e6\u30fc\u30b6\u30fc\u898f\u6a21\u3092\u60f3\u5b9a\u3057\u305f\u6700\u9069\u5316</li> </ul>"},{"location":"req/#_9","title":"\u4e92\u63db\u6027","text":"<ul> <li>\u30c7\u30b9\u30af\u30c8\u30c3\u30d7\u30d6\u30e9\u30a6\u30b6\uff08Chrome, Firefox, Safari, Edge\uff09</li> <li>\u30e2\u30d0\u30a4\u30eb\u30c7\u30d0\u30a4\u30b9\uff08iOS Safari, Android Chrome\uff09</li> <li>\u30bf\u30c3\u30c1\u30b9\u30af\u30ea\u30fc\u30f3\u5bfe\u5fdc</li> </ul>"},{"location":"req/#_10","title":"\u6280\u8853\u30b9\u30bf\u30c3\u30af","text":"<ul> <li>Pure JavaScript\uff08\u30d5\u30ec\u30fc\u30e0\u30ef\u30fc\u30af\u4e0d\u4f7f\u7528\uff09</li> <li>GitHub Pages \u3067\u30db\u30b9\u30c8</li> <li>\u30af\u30e9\u30a4\u30a2\u30f3\u30c8\u30b5\u30a4\u30c9\u306e\u307f\uff08\u30b5\u30fc\u30d0\u30fc\u4e0d\u8981\uff09</li> </ul>"},{"location":"req/#_11","title":"\u66f4\u65b0\u5c65\u6b74","text":"\u65e5\u4ed8 \u5185\u5bb9 2026-01-02 14\u7a2e\u306e\u5f79\u5224\u5b9a\u30e1\u30bd\u30c3\u30c9\u8ffd\u52a0\uff08checkIttsu\u7b49\uff09"}]}